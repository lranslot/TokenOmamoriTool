    <sys:String x:Key="RtkStep_Download_Failed">ダウンロード/展開に失敗しました: {0}（cargo導入にフォールバックします）</sys:String>
    <sys:String x:Key="RtkStep_Cargo">(フォールバック) Rust/cargoでソースからビルド</sys:String>
    <sys:String x:Key="RtkStep_Cargo_SkippedBinaryOk">バイナリ導入が成功済みのためスキップ</sys:String>
    <sys:String x:Key="RtkStep_Cargo_Failed">cargo installに失敗しました: {0}</sys:String>
    <sys:String x:Key="RtkStep_Cargo_Ok">cargo installでRTKを導入しました</sys:String>
    <sys:String x:Key="RtkStep_Rustup_Ok">rustupを導入しました</sys:String>
    <sys:String x:Key="RtkStep_Rustup_Failed">rustupの導入に失敗しました</sys:String>
    <sys:String x:Key="RtkStep_Rustup_DownloadFailed">rustupダウンロードに失敗しました: {0}</sys:String>
