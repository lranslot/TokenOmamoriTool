    <sys:String x:Key="RtkStep_VerifyGain">rtk gain で本物のRTKか確認（別パッケージ対策）</sys:String>
    <sys:String x:Key="RtkStep_VerifyGain_Ok">rtk gain 実行成功</sys:String>
