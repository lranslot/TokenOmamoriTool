<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <!-- windows10.0.17763.0: required by Microsoft.Toolkit.Uwp.Notifications (toast). Do not
         downgrade to plain net8.0-windows or the toast APIs disappear from the package. -->
    <TargetFramework>net8.0-windows10.0.17763.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <!-- Keep in sync with the git tag vX.Y.Z and the release ZIP name (spec §13.3);
         tools/publish.ps1 reads this value for the output names. -->
    <Version>1.0.0</Version>
    <!-- Generated from OmamoriShape/OmamoriTheme by tools/generate-icons.ps1 (spec §12.4) —
         rerun that script instead of editing the .ico files. -->
    <ApplicationIcon>Assets\omamori.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <Resource Include="Assets\omamori.ico" />
    <Resource Include="Assets\omamori-warning.ico" />
  </ItemGroup>

  <ItemGroup>
    <!-- 2.3.2 is the newest H.NotifyIcon.Wpf shipping a net8.0-windows asset
         (2.4.x only ships net462/net10.0-windows). -->
    <PackageReference Include="H.NotifyIcon.Wpf" Version="2.3.2" />
    <PackageReference Include="Microsoft.Toolkit.Uwp.Notifications" Version="7.1.3" />
  </ItemGroup>

</Project>
