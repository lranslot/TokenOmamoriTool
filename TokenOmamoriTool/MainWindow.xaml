<Window x:Class="TokenOmamoriTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TokenOmamoriTool"
        xmlns:conv="clr-namespace:TokenOmamoriTool.Converters"
        mc:Ignorable="d"
        Title="{DynamicResource AppTitle}" Width="300" SizeToContent="Height"
        Icon="/Assets/omamori.ico" Background="{StaticResource WashiBackground}"
        ResizeMode="CanMinimize" ContextMenuOpening="Window_ContextMenuOpening">
    <Window.Resources>
        <conv:RatioToGridLengthConverter x:Key="RatioToGridLength" />
        <conv:UsageFractionToBrushConverter x:Key="UsageToBrush" />

        <DataTemplate x:Key="MetricBarTemplate">
            <StackPanel Margin="0,3,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <!-- The main window is fixed at 300px wide (spec), so anything that can't fit
                         is ellipsized with the full text available on hover. -->
                    <TextBlock Grid.Column="0" Text="{Binding Label, Mode=OneWay}" FontSize="10" Foreground="Gray"
                               TextTrimming="CharacterEllipsis" ToolTip="{Binding Label, Mode=OneWay}" Margin="0,0,6,0" />
                    <TextBlock Grid.Column="1" Text="{Binding ValueText, Mode=OneWay}" FontSize="10" Foreground="Gray"
                               TextTrimming="CharacterEllipsis" ToolTip="{Binding ValueText, Mode=OneWay}" />
                </Grid>
                <Border Height="8" Background="#E0E0E0" CornerRadius="3" Margin="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="{Binding Ratio, Mode=OneWay, Converter={StaticResource RatioToGridLength}}" />
                            <ColumnDefinition Width="{Binding TrackRatio, Mode=OneWay, Converter={StaticResource RatioToGridLength}}" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" CornerRadius="3"
                                Background="{Binding UsageFraction, Mode=OneWay, Converter={StaticResource UsageToBrush}}" />
                    </Grid>
                </Border>
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <!-- §12.5: washi background with lightly rounded corners. §12.6 rules out transparent/shaped
         windows, so the rounding is an inner accent-colored border, not the window itself. -->
    <Border Margin="5" Padding="7" CornerRadius="6" BorderThickness="1"
            BorderBrush="{StaticResource OmamoriAccent}" Background="{StaticResource WashiBackground}">
    <StackPanel x:Name="RootPanel" Background="Transparent">
        <!-- §12.5: in-window title strip — the mini omamori's pouch color follows the tray state
             (UpdateTrayState) so the status is visible without the tray. -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
            <Viewbox Width="14" Height="14" Margin="0,1,5,0" VerticalAlignment="Center">
                <Canvas Width="{x:Static local:OmamoriShape.CanvasSize}" Height="{x:Static local:OmamoriShape.CanvasSize}">
                    <Path x:Name="MiniOmamoriPouch" Data="{x:Static local:OmamoriShape.PouchGeometry}"
                          Fill="{StaticResource OmamoriHealthy}" />
                    <Path Data="{x:Static local:OmamoriShape.LoopGeometry}"
                          Fill="{StaticResource OmamoriAccent}" />
                </Canvas>
            </Viewbox>
            <TextBlock Text="{DynamicResource AppTitle}" FontWeight="Bold" FontSize="11"
                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                       ToolTip="{DynamicResource AppTitle}" />
        </StackPanel>

        <ItemsControl x:Name="ProjectsList">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#DDDDDD" BorderThickness="0,0,0,1" Padding="0,6">
                        <StackPanel>
                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="11"
                                       TextTrimming="CharacterEllipsis" ToolTip="{Binding Name}" />
                            <ContentControl Content="{Binding ClaudeMd.LinesBar}" ContentTemplate="{StaticResource MetricBarTemplate}" />
                            <ContentControl Content="{Binding ClaudeMd.SizeBar}" ContentTemplate="{StaticResource MetricBarTemplate}" />
                            <ContentControl Content="{Binding SessionLog.SizeBar}" ContentTemplate="{StaticResource MetricBarTemplate}" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Separator Margin="0,8,0,6" />

        <StackPanel>
            <TextBlock Text="{Binding RtkDisplayText}" FontSize="10" TextWrapping="Wrap" />
            <TextBlock Text="{Binding CcusageDisplayText}" FontSize="10" TextWrapping="Wrap" Margin="0,3,0,0" />
        </StackPanel>

        <!-- Donation milestone banner (spec §9.2): collapsed by default, only grows the window
             vertically — the 300px width never changes. -->
        <Border x:Name="DonationBanner" Visibility="Collapsed" Background="#FFF8E1"
                BorderBrush="#E0D5A8" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,8,0,0">
            <StackPanel>
                <TextBlock x:Name="DonationBannerText" TextWrapping="Wrap" FontSize="11" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                    <Button Content="{DynamicResource Donation_Support}" FontSize="11" Padding="8,2"
                            Margin="0,0,6,0" Click="DonationSupport_Click" />
                    <Button Content="{DynamicResource Common_Close}" FontSize="11" Padding="8,2"
                            Click="DonationClose_Click" />
                </StackPanel>
            </StackPanel>
        </Border>
    </StackPanel>
    </Border>
</Window>
